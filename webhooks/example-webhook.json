{
  "$schema": "harness-webhook@1",
  "id": "example-webhook",
  "name": "on_task_complete",
  "version": "1.0.0",
  "description": "Fires when the model marks a task as complete.",
  "trigger": {
    "type": "model_output",
    "condition": "output contains task_complete signal"
  },
  "endpoint": {
    "method": "POST",
    "url": "{{WEBHOOK_URL}}",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {{WEBHOOK_SECRET}}"
    },
    "body": {
      "event": "task_complete",
      "session_id": "{{SESSION_ID}}",
      "payload": "{{MODEL_OUTPUT}}"
    }
  },
  "retry": { "max_attempts": 3, "backoff_ms": 1000 },
  "created_at": "2026-04-20",
  "notes": "Replace WEBHOOK_URL and WEBHOOK_SECRET with your environment variables."
}
